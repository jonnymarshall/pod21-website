# Secrets - Environment Variables
# Copy this file to .env.local and fill in with your actual data
# .env.local is in .gitignore and won't be committed

# Invoices JSON (stringified) - REGENERATE when adding/updating invoices
# Run: node scripts/generate-env-secrets.js
# Then copy the output here
VITE_INVOICES_JSON='[{"id":"INV-001","customerName":"Customer Name","usdAmount":1000.00,"btcAddress":"bc1q..."}]'

# Company Info JSON (stringified) - STATIC (only set once)
# Copy from secrets/company-info.json, minified on one line
VITE_COMPANY_INFO_JSON='{"name":"Your Company","address":{"street":"123 Main St","city":"City","state":"State","zip":"12345"},"taxId":"XX-XXXXXXX","supportEmail":"support@company.com"}'
